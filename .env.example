# Copie ce fichier en .env et remplis les valeurs.
# (Ne commite JAMAIS le vrai .env — il contient des secrets.)

# --- Claude (couche IA) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Atlassian Jira Service Management (Cloud) ---
JIRA_BASE_URL=https://ton-site.atlassian.net
JIRA_EMAIL=toi@exemple.com
JIRA_API_TOKEN=ton-atlassian-api-token        # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT_KEY=SD

# --- Slack (optionnel : alertes d'escalade) ---
SLACK_WEBHOOK_URL=

# --- Postgres (correspond au docker-compose) ---
PGHOST=localhost
PGPORT=5432
PGUSER=smartdesk
PGPASSWORD=smartdesk
PGDATABASE=smartdesk
